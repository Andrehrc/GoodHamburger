@page "/"

@using GoodHamburger.App.Services
@using GoodHamburger.Models.DTOs

@inject OrderApiService Api
@inject NavigationManager Nav

<PageTitle>Cardápio — Good Hamburger</PageTitle>

<h1>Cardápio</h1>

@if (_menu is null)
{
    <p>Carregando cardápio…</p>
}
else
{
    <div class="menu-grid">
        @foreach (var item in _menu)
        {
            <div class="menu-card @(IsSelected(item.Code) ? "selected" : "")"
                 @onclick="() => ToggleItem(item)">
                <span class="menu-icon">@CategoryIcon(item.Category)</span>
                <div class="menu-info">
                    <strong>@item.Name</strong>
                    <span class="menu-code">@item.Code</span>
                </div>
                <span class="menu-price">R$ @item.Price.ToString("F2")</span>
                @if (IsSelected(item.Code))
                {
                    <span class="check">✓</span>
                }
            </div>
        }
    </div>

    <div class="order-summary">
        <h2>Seu pedido</h2>

        @if (!_selectedCodes.Any())
        {
            <p class="empty">Selecione itens no cardápio acima.</p>
        }
        else
        {
            <ul>
                @foreach (var code in _selectedCodes)
                {
                    var item = _menu.First(m => m.Code == code);
                    <li>@item.Name — R$ @item.Price.ToString("F2")</li>
                }
            </ul>
        }

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="alert error">@_error</div>
        }

        <button class="btn-primary" @onclick="PlaceOrder" disabled="@(!_selectedCodes.Any() || _loading)">
            @(_loading ? "Enviando…" : "Fazer pedido")
        </button>
    </div>
}

@code {
    private List<MenuItemDto>? _menu;
    private readonly List<string> _selectedCodes = new();
    private string _error = string.Empty;
    private bool _loading;

    protected override async Task OnInitializedAsync() =>
        _menu = await Api.GetMenuAsync();

    private bool IsSelected(string code) => _selectedCodes.Contains(code);

    private void ToggleItem(MenuItemDto item)
    {
        if (_selectedCodes.Contains(item.Code))
        {
            _selectedCodes.Remove(item.Code);
        }
        else
        {
            // Impede seleção de categoria duplicada antes mesmo de chamar a API
            var category = item.Category;
            var alreadyInCategory = _menu!
                .Where(m => m.Category == category && _selectedCodes.Contains(m.Code))
                .Any();

            if (alreadyInCategory)
            {
                _error = $"Você já selecionou um item da categoria {category}.";
                return;
            }

            _selectedCodes.Add(item.Code);
        }
        _error = string.Empty;
    }

    private async Task PlaceOrder()
    {
        _loading = true;
        _error   = string.Empty;

        var (order, error) = await Api.CreateOrderAsync(_selectedCodes);

        _loading = false;

        if (error is not null)
        {
            _error = error;
            return;
        }

        Nav.NavigateTo($"/orders/{order!.Id}");
    }

    private static string CategoryIcon(string category) => category switch
    {
        "Sandwich" => "🍔",
        "Side"     => "🍟",
        "Drink"    => "🥤",
        _          => "🍽️"
    };
}
